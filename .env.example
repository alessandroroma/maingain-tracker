NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: free key from https://api.data.gov/signup/ for USDA food search.
# Without it, the shared DEMO_KEY is used (lower rate limits).
USDA_API_KEY=

# Optional: Oura Personal Access Token for recovery sync.
# Generate at https://cloud.ouraring.com/personal-access-tokens
OURA_PAT=

# Optional: WHOOP recovery sync. Create an app at https://developer.whoop.com
# (redirect URL: https://<your-domain>/api/whoop/callback), then visit
# /api/whoop/auth once to authorize.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
